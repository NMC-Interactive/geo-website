{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/pb.mjs anchor" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/pb.mjs anchor --brief" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/pb.mjs checkpoint --snapshot" }
        ]
      }
    ]
  }
}
