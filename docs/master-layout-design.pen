                },
                {
                  "type": "frame",
                  "id": "ZEjCH",
                  "name": "Section Defining Generative Engine Optimization",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "tLJHK",
                      "name": "Section Heading",
                      "fill": "#FFFFFF",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Defining Generative Engine Optimization",
                      "lineHeight": 1.25,
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "letterSpacing": -0.6
                    },
                    {
                      "type": "text",
                      "id": "MU4sz",
                      "name": "Section Paragraph",
                      "fill": "#C4C4C4",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Generative Engine Optimization (GEO) is the strategic practice of optimizing a brand's digital presence — its content, authority signals, and technical infrastructure — to be discovered, trusted, and cited by generative AI engines such as ChatGPT, Perplexity, Google Gemini, DeepSeek, and Doubao.\n\nUnlike traditional SEO, which optimizes for ranking on search engine results pages, GEO optimizes for inclusion within AI-generated answers themselves — ensuring your brand is among those named when an AI synthesizes a response.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "mZBFI",
                  "name": "Section How GEO Works: The Technical Mechanism",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "smszU",
                      "name": "Section Heading",
                      "fill": "#FFFFFF",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "How GEO Works: The Technical Mechanism",
                      "lineHeight": 1.25,
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "letterSpacing": -0.6
                    },
                    {
                      "type": "text",
                      "id": "LYPqv",
                      "name": "Section Paragraph",
                      "fill": "#C4C4C4",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "To understand GEO, it helps to understand how generative AI search works — query processing, information retrieval, synthesis, and response generation. GEO optimizes for each of these stages in turn.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "M6PKxy",
                      "name": "Section List",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 8,
                      "padding": [
                        4,
                        0,
                        4,
                        8
                      ],
                      "children": [
