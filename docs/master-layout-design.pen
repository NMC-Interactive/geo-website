                },
                {
                  "type": "frame",
                  "id": "JYRov",
                  "name": "Section Why GEO Matters: The Strategic Case",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "NEzOJ",
                      "name": "Section Heading",
                      "fill": "#FFFFFF",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Why GEO Matters: The Strategic Case",
                      "lineHeight": 1.25,
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "letterSpacing": -0.6
                    },
                    {
                      "type": "text",
                      "id": "nPpuQ",
                      "name": "Section Paragraph",
                      "fill": "#C4C4C4",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The importance of GEO is driven by three converging trends: the rise of zero-click search, where AI assistants answer queries without a site visit; significantly higher conversion rates from AI-referred traffic; and a compounding authority advantage that rewards brands who establish trust early.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "seZLI",
                  "name": "Section The Core Components of GEO",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "UQy1B",
                      "name": "Section Heading",
                      "fill": "#FFFFFF",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The Core Components of GEO",
                      "lineHeight": 1.25,
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "letterSpacing": -0.6
                    },
                    {
                      "type": "text",
                      "id": "BlcDJ",
                      "name": "Section Paragraph",
                      "fill": "#C4C4C4",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Effective GEO consists of four integrated components — content optimization for AI extraction, entity building across the web, authority development through original research and expert authorship, and technical enablement so AI crawlers can access and parse your content.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "zZ03g",
                  "name": "Primary Sources Section",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "jX9pJ",
                      "name": "Primary Sources Heading",
                      "fill": "#FFFFFF",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Primary Sources & Citation Framework",
                      "lineHeight": 1.25,
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "letterSpacing": -0.6
                    },
                    {
                      "type": "text",
                      "id": "fynx2",
                      "name": "Primary Sources Intro",
                      "fill": "#C4C4C4",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Role-model GEO articles should show where claims come from. This template includes a source layer for research papers, platform documentation, regulations, and first-party methodology so readers and AI systems can trace evidence quickly.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
