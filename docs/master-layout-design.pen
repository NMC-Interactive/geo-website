                {
                  "type": "frame",
                  "id": "q0vYtw",
                  "name": "Entity Coverage Section",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "U5OAvs",
                      "name": "Entity Coverage Heading",
                      "fill": "#FFFFFF",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Entity Coverage & Retrieval Targets",
                      "lineHeight": 1.25,
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "letterSpacing": -0.6
                    },
                    {
                      "type": "text",
                      "id": "Q80QI",
                      "name": "Entity Coverage Intro",
                      "fill": "#C4C4C4",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "A GEO role-model page should make its topic entities visible and consistent. These labels represent the systems, concepts, and retrieval targets this article is intentionally optimized to connect.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
