                        },
                        {
                          "type": "text",
                          "id": "Al73S",
                          "name": "AI-Readable Summary Body",
                          "fill": "#D3D7DF",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Generative Engine Optimization (GEO) is the practice of improving how a brand is discovered, understood, and cited inside AI-generated answers. It combines content clarity, entity authority, technical markup, and source credibility so generative engines can retrieve and reference the right information. For this site, GEO is treated as a visibility discipline built for answer systems rather than only ranking systems.",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
