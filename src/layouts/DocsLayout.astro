---
import '../styles/global.css';
import { buildOrganizationJsonLd, CONTACT_EMAIL, DEFAULT_OG_IMAGE, SITE_DESCRIPTION, SITE_TITLE_SUFFIX } from '../utils/site';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  structuredData?: Record<string, any> | Array<Record<string, any>>;
}

const { title, description = SITE_DESCRIPTION, canonical, image = DEFAULT_OG_IMAGE, structuredData } = Astro.props;
const pageTitle = `${title} | ${SITE_TITLE_SUFFIX}`;
const canonicalUrl = canonical ? new URL(canonical, Astro.site).href : Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const imageUrl = Astro.site ? new URL(image, Astro.site).href : image;
const jsonLd = [buildOrganizationJsonLd(Astro.site), ...(Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : [])].filter(Boolean);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
  <meta property="og:type" content="article" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
  {imageUrl && <meta property="og:image" content={imageUrl} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  {imageUrl && <meta name="twitter:image" content={imageUrl} />}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
  {jsonLd.map((item) => (
    <script type="application/ld+json" set:html={JSON.stringify(item)} />
  ))}
</head>
<body class="bg-[#050505] text-white">
  <nav style="border-bottom: 1px solid rgba(255,255,255,0.08);">
    <div class="max-w-6xl mx-auto px-8 py-5 flex justify-between items-center">
      <a href="/" class="flex flex-col items-start leading-none">
        <span class="font-display text-white" style="font-size: 0.95rem; letter-spacing: 0.06em; font-weight: 700; line-height: 1.1;">
          Visibility Guide
        </span>
        <span class="font-serif italic" style="font-size: 0.62rem; color: #A0A0A0; letter-spacing: 0.04em; line-height: 1.3; margin-top: 1px;">
          by NMC Interactive
        </span>
      </a>
      <div class="flex gap-8" style="font-size: 0.75rem;">
        <a href="/geo-fundamentals/" class="nav-link-underline font-mono uppercase tracking-widest text-[#A0A0A0] hover:text-white transition-colors duration-200" style="letter-spacing: 0.12em;">GEO</a>
        <a href="/geo-fundamentals/geo-vs-seo/" class="nav-link-underline font-mono uppercase tracking-widest text-[#A0A0A0] hover:text-white transition-colors duration-200" style="letter-spacing: 0.12em;">SEO</a>
        <a href="/sitemap/" class="nav-link-underline font-mono uppercase tracking-widest text-[#A0A0A0] hover:text-white transition-colors duration-200" style="letter-spacing: 0.12em;">Tutorials</a>
        <a href={`mailto:${CONTACT_EMAIL}`} class="nav-link-underline font-mono uppercase tracking-widest text-[#A0A0A0] hover:text-white transition-colors duration-200" style="letter-spacing: 0.12em;">Contact</a>
      </div>
    </div>
  </nav>

  <div class="max-w-3xl mx-auto px-8 py-16">
    <slot />
  </div>

  <footer style="border-top: 1px solid rgba(255,255,255,0.06); padding: 1.5rem 2rem; text-align: center;">
    <span class="font-mono text-xs text-[#A0A0A0]" style="letter-spacing: 0.06em;">
      © {new Date().getFullYear()} NMC Interactive · GEO / SEO
    </span>
  </footer>
</body>
</html>
