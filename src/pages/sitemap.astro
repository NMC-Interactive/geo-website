---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Complete Sitemap">
  <nav class="border-b border-zinc-800 bg-[#050505]">
    <div class="max-w-6xl mx-auto px-8 py-5 flex justify-between">
      <a href="/" class="text-2xl font-bold tracking-[-0.04em]">GEO</a>
    </div>
  </nav>

  <div class="max-w-5xl mx-auto px-8 py-16">
    <h1 class="text-6xl font-semibold tracking-[-2px] mb-12">Complete Sitemap</h1>

    <div class="space-y-16 text-sm">
      <!-- GEO Fundamentals -->
      <div>
        <div class="text-xs tracking-[3px] text-zinc-500 mb-4">CLUSTER 01 — GEO FUNDAMENTALS</div>
        <div class="grid md:grid-cols-2 gap-x-12 gap-y-2 text-lg">
          <a href="/docs/fundamentals/what-is-geo" class="hover:text-blue-400">What is GEO?</a>
          <a href="/docs/fundamentals/history-of-geo" class="hover:text-blue-400">History and Evolution of GEO</a>
          <a href="/docs/fundamentals/geo-vs-seo" class="hover:text-blue-400">GEO vs Traditional SEO</a>
          <a href="/docs/fundamentals/how-generative-engines-work" class="hover:text-blue-400">How Generative Engines Work</a>
        </div>
      </div>

      <!-- Strategies -->
      <div>
        <div class="text-xs tracking-[3px] text-zinc-500 mb-4">CLUSTER 02 — STRATEGIES</div>
        <div class="grid md:grid-cols-2 gap-x-12 gap-y-2 text-lg">
          <a href="/docs/strategies/core-geo-strategies" class="hover:text-blue-400">Core GEO Strategies</a>
          <a href="/docs/strategies/e-e-a-t-optimization" class="hover:text-blue-400">E-E-A-T Optimization</a>
          <a href="/docs/strategies/content-structuring" class="hover:text-blue-400">Content Structuring for AI</a>
          <a href="/docs/strategies/citation-optimization" class="hover:text-blue-400">Citation &amp; Source Optimization</a>
        </div>
      </div>

      <!-- Advanced -->
      <div>
        <div class="text-xs tracking-[3px] text-zinc-500 mb-4">CLUSTER 03 — ADVANCED</div>
        <div class="grid md:grid-cols-2 gap-x-12 gap-y-2 text-lg">
          <a href="/docs/advanced/measurement" class="hover:text-blue-400">Measuring GEO Success</a>
          <a href="/docs/advanced/tools" class="hover:text-blue-400">GEO Tools &amp; Platforms</a>
          <a href="/docs/advanced/case-studies" class="hover:text-blue-400">Case Studies</a>
        </div>
      </div>
    </div>
  </div>
</Layout>